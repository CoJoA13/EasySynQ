# EasySynQ environment template (12-factor, D1). Copy to .env (0600) — never commit .env.
# install.sh generates the CHANGE_ME secrets at first run.

# --- core ---
EASYSYNQ_ENV=production
EASYSYNQ_PROFILE=s                       # s | m  (l reserved, not MVP)
EASYSYNQ_ORG_TIMEZONE=UTC                # IANA tz; effective-date capture (R8)
LOG_LEVEL=INFO

# --- database (PostgreSQL 16) — ROLE SEPARATION (S6, AC#6a) ---
# api/worker/beat connect as the NON-OWNER easysynq_app role (INSERT/SELECT-only on audit_event +
# signature_event, so the append-only trail is structurally enforced). Alembic (the migrate
# service) connects as the OWNER (POSTGRES_USER) so the 0010 migration can CREATE ROLE + GRANT.
DATABASE_URL=postgresql+psycopg://easysynq_app:CHANGE_ME_APP@postgres:5432/easysynq
DATABASE_URL_SYNC=postgresql+psycopg://easysynq:CHANGE_ME@postgres:5432/easysynq  # alembic = owner
# The chain-linker connects as a dedicated role with column-scoped UPDATE on the audit hash cols.
AUDIT_LINKER_DATABASE_URL=postgresql+psycopg://easysynq_linker:CHANGE_ME_LINKER@postgres:5432/easysynq
# Passwords the 0010 migration uses to CREATE the app + linker roles (must match the DSNs above).
APP_DB_PASSWORD=CHANGE_ME_APP
LINKER_DB_PASSWORD=CHANGE_ME_LINKER

# --- redis (broker / cache / locks / rate-limit / permissions-epoch) ---
REDIS_URL=redis://redis:6379/0

# --- object store (S3 API via boto3 — swap-clean to AWS S3 / Azure per D2/D4) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET_DOCUMENTS=documents
S3_BUCKET_RENDITIONS=renditions
S3_BUCKET_RECORDS=records                # created in MVP; record capture is v1
S3_BUCKET_STAGING=staging
S3_BUCKET_RESTORE_SCRATCH=restore-scratch # S8b2: plain (non-WORM) scratch bucket for the restore drill
S3_BUCKET_IMPORT_STAGING=import-staging   # S-ing-1: plain (non-WORM) staging for imported source bytes
S3_OBJECT_LOCK_MODE=GOVERNANCE           # GOVERNANCE (default) | COMPLIANCE (hardened opt-in) — D-7

# --- S-ing-1 ingestion (doc 09, UJ-2): point IMPORT_SOURCE_PATH at the existing QMS file tree to
# import (a host dir). The worker mounts it READ-ONLY at IMPORT_SOURCE_ROOT (NG3); a run's source_root
# must resolve WITHIN that root (path-traversal/symlink-escape are rejected). Defaults let `just up`
# work with an empty ./.import-source dir. ---
IMPORT_SOURCE_PATH=./.import-source
IMPORT_SOURCE_ROOT=/srv/import/source

# --- S-ing-2 ingestion extract + classify (doc 09 §5-6): the worker extracts text/metadata + OCRs
# scanned PDFs/images via the Apache Tika `-full` sidecar (HTTP, fully local). OCR is gated per-run by
# the create body's `ocr_enabled`; IMPORT_OCR_LANGUAGE is the Tesseract default. ---
TIKA_URL=http://tika:9998
IMPORT_OCR_LANGUAGE=eng

# --- S6 off-host audit-checkpoint sink (R13/D-8): a separate object-lock bucket reached with
# DISTINCT, write-only credentials held apart from the vault root (custody separation). Point this
# at a genuinely off-host/external endpoint before claiming tamper-evidence (the soft-gate stays
# false otherwise). minio-init.sh provisions the bucket + the scoped audit-sink user in dev.
S3_BUCKET_AUDIT_CHECKPOINTS=audit-checkpoints
AUDIT_SINK_ACCESS_KEY=audit-sink
AUDIT_SINK_SECRET_KEY=CHANGE_ME_AUDIT_SINK

# --- auth (Keycloak; API is an OAuth2 resource server) ---
OIDC_ISSUER=https://auth.example/realms/easysynq
OIDC_AUDIENCE=easysynq-api
OIDC_JWKS_URL=https://auth.example/realms/easysynq/protocol/openid-connect/certs

# --- S11 Keycloak realm export (the worker reaches the Admin REST API on the INTERNAL network to
# bundle the live realm into the backup; a Keycloak outage degrades the realm leg to "absent",
# never failing the backup). KEYCLOAK_ADMIN_USER/PASSWORD also seed the Keycloak admin account. ---
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME         # generated by install.sh

# --- renderer (Gotenberg) ---
GOTENBERG_URL=http://renderer:3000

# --- read-only filesystem mirror (worker-writable, user-RO; R11) ---
MIRROR_PATH=/var/lib/easysynq/qms-mirror

# --- S8b2 backup: default durable-archive destination (a mounted volume / NFS path). The per-org
# backup_policy.destination overrides. The restore-test drill + pg_dump run as the OWNER role, so
# the worker must see DATABASE_URL_SYNC (the owner DSN, set above for Alembic). ---
BACKUP_PATH=/var/lib/easysynq/backups

# --- secrets sealed by the app master KEK (never the plaintext DEKs) ---
APP_MASTER_KEK=CHANGE_ME                 # generated by install.sh, file 0600
BACKUP_ENCRYPTION_KEY=CHANGE_ME

# --- audit-checkpoint signing key (MVP scope; distinct from deferred Part-11 crypto) ---
AUDIT_CHECKPOINT_SIGNING_KEY_PATH=/run/secrets/audit_ckpt_key

# --- S7c verify-token signing key (shared api+worker via the `secrets` volume) + public origin ---
# The worker mints the controlled-copy verify token; the api verifies it on the public /verify page,
# so they must share this key. PUBLIC_BASE_URL is the browser-reachable origin the footer QR points at.
VERIFY_TOKEN_SIGNING_KEY_PATH=/run/secrets/verify_token_key
PUBLIC_BASE_URL=http://localhost

# --- dev SMTP catcher (Mailpit) — email is best-effort in MVP ---
SMTP_HOST=mailpit
SMTP_PORT=1025
