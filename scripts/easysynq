#!/usr/bin/env bash
# EasySynQ admin CLI (host-side). Dispatches to backup / restore / mirror / upgrade.
# In S0 these are skeletons; the real implementations land in slice S11 (backup/restore,
# WORM-aware restore R37) and S7 (mirror rebuild).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
COMPOSE=(docker compose --env-file "$ROOT/.env" -f "$ROOT/infra/compose/compose.yml")

usage() {
  cat <<'EOF'
usage: easysynq <command>

  backup run        Write a durable checksummed archive (pg_dump + MinIO blob
                    manifest) to each configured destination.            [S8b2]
  backup restore-test
                    Run the backup->restore-into-scratch drill + integrity triad
                    (gate G-C); persists PASS/FAIL.                      [S8b2]
  restore <file> --confirm [--audit-checkpoint-ack]
                    WORM-aware live restore to a VERIFIED TARGET (fresh bucket;
                    blob-snapshot aligned; checkpoint-not-ahead check; chain
                    re-verify). Leaves a standing target; cut over per runbook. [S11]
  mirror rebuild    Regenerate the read-only filesystem mirror from the vault. [S7]
  blob verify [--full] [--sample-size N]
                    D1 integrity re-hash of vault blobs against blob.sha256
                    (rolling sample by default; --full = the complete pass;
                    re-run after a restore to clear the alarm).        [S-drift-3]
  upgrade --confirm Pre-backup -> migrate -> health-gate (pre-backup is the
                    disaster safety net on a failed migration).             [S11]
  migrate           Run 'alembic upgrade head' inside the api image.
  grant-role <sub> ["Role"]
                    Break-glass: assign a seeded role (default "System
                    Administrator") to a Keycloak subject directly (bypasses the
                    wizard). Idempotent.                                     [S2]
  setup mint-bootstrap [--ttl-hours N]
                    Mint the one-time first-run bootstrap secret; open /setup,
                    sign in, and paste it to become the first admin.        [S8a]
  seed-personas --author <sub> --approver <sub> --releaser <sub>
                    Dev fixture: SoD-correct Priya(author)/Ken(approver)/Mara
                    (releaser) grants for the full lifecycle. Idempotent.
                    (Use `just seed-personas` to also create the logins.)    [dev]
EOF
}

cmd="${1:-}"; shift || true
case "$cmd" in
  migrate)
    "${COMPOSE[@]}" run --rm migrate
    ;;
  grant-role)
    sub="${1:-}"; role="${2:-System Administrator}"
    if [ -z "$sub" ]; then
      echo 'usage: easysynq grant-role <keycloak-subject> ["Role Name"]' >&2
      exit 2
    fi
    "${COMPOSE[@]}" run --rm api uv run python -m easysynq_api.cli.grant_role --subject "$sub" --role "$role"
    ;;
  seed-personas)
    # Dev fixture: SoD-correct author/approver/releaser grants (S-web-5 demo). `just seed-personas`
    # wraps this and also provisions the matching Keycloak logins. Idempotent.
    "${COMPOSE[@]}" run --rm api uv run python -m easysynq_api.cli.seed_personas "$@"
    ;;
  setup)
    # First-run bootstrap (S8a): e.g. `easysynq setup mint-bootstrap [--ttl-hours 24]`.
    "${COMPOSE[@]}" run --rm api uv run python -m easysynq_api.cli.setup "$@"
    ;;
  backup)
    # S8b2: durable backup (`backup run`) + the restore-into-scratch drill (`backup restore-test`,
    # gate G-C). Runs on the WORKER (it carries postgresql-client + the owner DATABASE_URL_SYNC).
    "${COMPOSE[@]}" run --rm worker uv run python -m easysynq_api.cli.backup "$@"
    ;;
  restore)
    # S11 (R37): WORM-aware *live* restore to a VERIFIED TARGET (fresh bucket; blob-snapshot
    # alignment; checkpoint-not-ahead tamper check; restored-chain re-verify). Leaves a standing,
    # ready-to-cutover target — the production cutover is a documented operator step (runbook).
    # Runs on the WORKER (OWNER DATABASE_URL_SYNC + postgresql-client).
    "${COMPOSE[@]}" run --rm worker uv run python -m easysynq_api.cli.restore "$@"
    ;;
  upgrade)
    # S11: pre-backup -> alembic upgrade head -> readiness health-gate (the pre-backup is the
    # disaster safety net; a failed migration auto-rolls-back its txn). Runs on the WORKER.
    "${COMPOSE[@]}" run --rm worker uv run python -m easysynq_api.cli.upgrade "$@"
    ;;
  mirror)
    "${COMPOSE[@]}" run --rm api uv run python -m easysynq_api.cli.mirror "$@"
    ;;
  blob)
    # S-drift-3 (D1): rolling/--full blob integrity re-hash under LOCK_BLOB_VERIFY. Runs on the
    # WORKER (the same internal-read path the Beat task uses; exit 1 on a FAILED infra scan).
    "${COMPOSE[@]}" run --rm worker uv run python -m easysynq_api.cli.blob "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "unknown command: $cmd" >&2
    usage
    exit 2
    ;;
esac
