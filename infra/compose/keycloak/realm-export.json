{
  "realm": "easysynq",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "failureFactor": 5,
  "waitIncrementSeconds": 900,
  "maxFailureWaitSeconds": 900,
  "passwordPolicy": "length(12) and notUsername(undefined)",
  "clients": [
    {
      "clientId": "easysynq-web",
      "name": "EasySynQ SPA",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost/*", "https://localhost/*", "http://easysynq.local/*", "https://easysynq.local/*"],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "audience-easysynq-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "easysynq-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "easysynq-api",
      "name": "EasySynQ API (resource server)",
      "bearerOnly": true,
      "publicClient": false
    }
  ],
  "defaultDefaultClientScopes": ["profile", "email", "roles"]
}
