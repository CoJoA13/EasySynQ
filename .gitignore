packages/contracts/dist/
apps/api/src/easysynq_api/_generated/
apps/web/src/api/_generated/

# --- python ---
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# --- node / web ---
node_modules/
apps/web/dist/
apps/web/.vite/
*.log
npm-debug.log*

# --- os / editor ---
.DS_Store
.idea/
.vscode/
*.swp

# --- runtime data (never committed) ---
infra/data/
qms-mirror/
backups/
